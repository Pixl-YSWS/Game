HACKCLUB_CLIENT_ID=
HACKCLUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
CLIENT_URL=http://localhost:5173
# PORT=3001
# DATA_DIR=/data                # SQLite location; point at a mounted volume in prod (e.g. Railway)
# ALLOW_GUEST=false             # disable guest login in production
# OPENWORLD_VERIFIED_ONLY=true  # restrict the open world to Hack Club "verified" accounts
# VITE_SERVER_URL=http://localhost:3001

# ── YSWS store (projects + user identity) ───────────────────────────
# Hack Club's YSWS pipeline expects an Airtable-shaped store, so projects (and
# the user identity behind them) live in Postgres via Drizzle (server/db.ts),
# returned in the Airtable { records: [{ id, fields }] } shape. The rest of the
# game still uses SQLite (DATA_DIR above). Works with plain Postgres or Neon
# (SSL auto-enabled for *.neon.tech URLs). Tables auto-create on boot; for
# schema changes use `bunx drizzle-kit push`.
# Leave unset for local dev — the projects feature just no-ops (fails soft).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Hackatime (coding-time tracking for projects) ───────────────────
# Players connect their Hackatime account in-game via OAuth (no key pasting).
# Register an app at https://hackatime.hackclub.com/oauth/applications with
# redirect URI http://localhost:3001/hackatime/callback, scope "read", and the
# "Confidential" box checked, then fill these in.
HACKATIME_CLIENT_ID=
HACKATIME_CLIENT_SECRET=
# HACKATIME_REDIRECT_URI=http://localhost:3001/hackatime/callback
# HACKATIME_API_BASE=https://hackatime.hackclub.com   # override only if the host moves
# HACKATIME_SCOPES=read

# ── Moderation / admin ──────────────────────────────────────────────
# Password for the offline admin CLI (server/admin-cli.ts). Required to run it.
# ADMIN_SECRET=canbeanythinggng
# Extra built-in root admins by email (comma-separated). riditjangra09@gmail.com
# is always a root admin; add more here without code changes.
# ADMIN_EMAILS=someone@example.com,other@example.com
